# ==================== DATA MODELS ====================
class VideoMetadata(BaseModel):
    video_id: str
    platform: str
    title: str
    creator: str
    follower_count: int
    views: int
    likes: int
    comments: int
    duration: int
    upload_date: str
    hashtags: List[str]
    url: str

    @property
    def engagement_rate(self) -> float:
        if self.views == 0:
            return 0
        return ((self.likes + self.comments) / self.views) * 100

class ChatRequest(BaseModel):
    video_a_url: str
    video_b_url: str
    question: str
    conversation_history: Optional[List[dict]] = None

